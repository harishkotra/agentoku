# General
SOLVE_MODE=full
PUZZLE_LEVEL=easy
AGENT_TIMEOUT_MS=30000
AGENT_RETRIES=2
MAX_STEP_COUNT=150
STEP_DELAY_MS=350
VERBOSE_LOGS=true

# Web UI
WEB_PORT=3000

# OpenAI (official SDK)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama
ENABLE_OLLAMA=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# LM Studio (OpenAI-compatible local endpoint)
ENABLE_LMSTUDIO=true
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=local-model

# Featherless.ai (OpenAI-compatible)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=featherless-chat
